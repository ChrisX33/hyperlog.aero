---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="bg-surface-container p-6 rounded-lg ghost-border flex flex-col gap-4">
  <div class="w-12 h-12 bg-primary/10 flex items-center justify-center rounded">
    <span class="text-2xl text-primary">{icon}</span>
  </div>
  <h4 class="text-lg font-bold text-white">{title}</h4>
  <p class="text-sm text-secondary leading-relaxed">{description}</p>
</div>
