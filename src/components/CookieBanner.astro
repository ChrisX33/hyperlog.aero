---

<div id="hl-consent" style="display:flex;position:fixed;inset:0;z-index:100;align-items:center;justify-content:center;padding:1rem;">
  <!-- Overlay -->
  <div style="position:absolute;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);"></div>

  <!-- Banner card -->
  <div style="position:relative;background:#142032;border-radius:0.75rem;border:1px solid rgba(66,70,85,0.2);padding:2rem;max-width:28rem;width:100%;box-shadow:0 25px 50px -12px rgba(0,0,0,0.25);">
    <!-- Close button -->
    <button onclick="document.getElementById('hl-consent').style.display='none';document.documentElement.style.overflow='';localStorage.setItem('cookie-consent','declined');window.dispatchEvent(new CustomEvent('cookie-consent-update',{detail:'declined'}))" style="position:absolute;top:1rem;right:1rem;background:none;border:none;color:#8FA3BF;cursor:pointer;" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <!-- Logo -->
    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem;">
      <img src="/logo/logo-icon.svg" alt="" style="width:1.5rem;height:1.5rem;" />
      <span style="font-size:0.875rem;font-weight:700;color:#b2c5ff;">HyperLog</span>
    </div>

    <h3 style="font-size:1.125rem;font-weight:700;color:#fff;margin-bottom:0.75rem;">Cookie Preferences</h3>
    <p style="font-size:0.875rem;color:#b4c8e5;line-height:1.625;margin-bottom:1rem;">
      We use cookies to understand how visitors use our website. Analytics cookies are only used with your consent. You can change your preferences at any time.
    </p>

    <div style="display:flex;gap:0.75rem;margin-bottom:1rem;">
      <a href="/privacy" style="font-size:0.75rem;color:#b2c5ff;text-decoration:none;">Privacy Policy</a>
      <a href="/cookies" style="font-size:0.75rem;color:#b2c5ff;text-decoration:none;">Cookie Policy</a>
    </div>

    <div style="display:flex;gap:0.75rem;">
      <button onclick="document.getElementById('hl-consent').style.display='none';document.documentElement.style.overflow='';localStorage.setItem('cookie-consent','declined');window.dispatchEvent(new CustomEvent('cookie-consent-update',{detail:'declined'}))" style="flex:1;padding:0.75rem;border:1px solid rgba(66,70,85,0.3);background:none;color:#fff;font-weight:700;font-size:0.875rem;border-radius:9999px;cursor:pointer;">
        Decline
      </button>
      <button onclick="document.getElementById('hl-consent').style.display='none';document.documentElement.style.overflow='';localStorage.setItem('cookie-consent','accepted');window.dispatchEvent(new CustomEvent('cookie-consent-update',{detail:'accepted'}))" style="flex:1;padding:0.75rem;border:none;background:#b2c5ff;color:#002b73;font-weight:700;font-size:0.875rem;border-radius:9999px;cursor:pointer;">
        Accept
      </button>
    </div>
  </div>
</div>
<script is:inline>
if(localStorage.getItem('cookie-consent')){
  document.getElementById('hl-consent').style.display='none';
}else{
  document.documentElement.style.overflow='hidden';
}
</script>
