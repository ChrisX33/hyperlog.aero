---
interface Props {
  tier: number;
  title: string;
  description: string;
  features: string[];
  icon: string;
  highlighted?: boolean;
}

const { tier, title, description, features, icon, highlighted = false } = Astro.props;
const tierLabel = `TIER 0${tier}`;
const borderClass = highlighted ? 'border-primary/30' : 'ghost-border';
---

<div class={`group p-8 rounded-lg bg-surface-low transition-all relative overflow-hidden ${borderClass}`}>
  {highlighted && (
    <div class="absolute top-0 right-0 p-4">
      <span class="text-[10px] font-black tracking-widest text-primary bg-primary/10 px-2 py-1 rounded">CORE</span>
    </div>
  )}
  <div class="flex justify-between items-start mb-6">
    <div class={`${highlighted ? 'bg-primary/20' : 'bg-surface-highest'} p-3 rounded`}>
      <span class="text-2xl text-primary">{icon}</span>
    </div>
    <span class="text-[10px] font-bold tracking-[0.1em] text-outline">{tierLabel}</span>
  </div>
  <h3 class="text-2xl font-bold text-white mb-3">{title}</h3>
  <p class="text-secondary text-sm leading-relaxed mb-6">{description}</p>
  <div class="h-px bg-outline-variant/10 w-full mb-6"></div>
  <ul class="space-y-3">
    {features.map(feature => (
      <li class="flex items-center gap-2 text-xs text-on-surface-variant">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        {feature}
      </li>
    ))}
  </ul>
</div>
