---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact - HyperLog">
  <Header />

  <main class="flex-grow pt-24">

    <!-- Logo -->
    <section class="pt-6 pb-12 px-6 flex justify-center bg-surface-base">
      <img src="/logo/logo-full-on-dark.svg" alt="HyperLog" class="w-[250px] md:w-[300px]" />
    </section>

    <!-- ============================================================
         CONTACT
         ============================================================ -->
    <section class="py-16 px-6 bg-surface-base">
      <div class="max-w-5xl mx-auto">
        <p class="section-label text-primary mb-4">Get in Touch</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-10 tracking-tight">Contact Us</h2>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

          <!-- LEFT: Contact Form -->
          <div class="lg:col-span-3">
            <div class="bg-surface-container rounded-xl border border-primary/20 p-3 sm:p-5 md:p-8">
              <form id="contact-form" class="space-y-5">
                <div>
                  <label for="name" class="block text-xs font-bold tracking-[0.1em] uppercase text-secondary mb-2">Name *</label>
                  <input type="text" id="name" name="name" required maxlength="100" class="w-full bg-surface-low border border-outline-variant/20 rounded-lg px-4 py-3 text-sm text-white placeholder-outline/40 focus:outline-none focus:border-primary/50 transition-colors" placeholder="Your full name" />
                </div>

                <div>
                  <label for="email" class="block text-xs font-bold tracking-[0.1em] uppercase text-secondary mb-2">Email *</label>
                  <input type="email" id="email" name="email" required class="w-full bg-surface-low border border-outline-variant/20 rounded-lg px-4 py-3 text-sm text-white placeholder-outline/40 focus:outline-none focus:border-primary/50 transition-colors" placeholder="you@example.com" />
                </div>

                <div>
                  <label for="company" class="block text-xs font-bold tracking-[0.1em] uppercase text-secondary mb-2">Organisation</label>
                  <input type="text" id="company" name="company" maxlength="100" class="w-full bg-surface-low border border-outline-variant/20 rounded-lg px-4 py-3 text-sm text-white placeholder-outline/40 focus:outline-none focus:border-primary/50 transition-colors" placeholder="Airline, authority, or organisation" />
                </div>

                <div>
                  <label for="message" class="block text-xs font-bold tracking-[0.1em] uppercase text-secondary mb-2">Message *</label>
                  <textarea id="message" name="message" required rows="4" minlength="10" maxlength="2000" class="w-full bg-surface-low border border-outline-variant/20 rounded-lg px-4 py-3 text-sm text-white placeholder-outline/40 focus:outline-none focus:border-primary/50 transition-colors resize-none" placeholder="Tell us about your interest in HyperLog - are you a pilot, airline, regulator, or flight school?"></textarea>
                </div>

                <div class="flex items-start gap-3">
                  <input type="checkbox" id="privacy" name="privacy" required class="mt-1 shrink-0 accent-primary cursor-pointer" />
                  <label for="privacy" class="text-xs text-secondary leading-relaxed cursor-pointer">
                    I have read and accept the <a href="/privacy" target="_blank" class="text-primary hover:text-white transition-colors underline">Privacy Policy</a>
                  </label>
                </div>

                <!-- Cloudflare Turnstile -->
                <div id="turnstile-wrapper" class="w-full overflow-hidden">
                  <div id="turnstile-container" class="cf-turnstile" data-sitekey="0x4AAAAAAC0RLz9YOUx_4VYY" data-theme="dark" data-size="flexible"></div>
                </div>

                <button type="submit" id="contact-submit" disabled class="w-full bg-primary text-on-primary font-bold py-3.5 rounded-full text-sm tracking-widest uppercase hover:opacity-90 transition-opacity disabled:opacity-40 disabled:cursor-not-allowed">
                  Send Message
                </button>
              </form>

              <!-- Success state (hidden by default) -->
              <div id="contact-success" class="hidden text-center py-12">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="1.5" class="mx-auto mb-4"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <h3 class="text-xl font-bold text-white mb-2">Message Sent</h3>
                <p class="text-sm text-secondary mb-6">We typically respond within one business day.</p>
                <button id="send-another" class="text-sm text-primary font-semibold hover:text-white transition-colors cursor-pointer">Send Another Message</button>
              </div>
            </div>
          </div>

          <!-- RIGHT: Contact Info + What to Expect -->
          <div class="lg:col-span-2 flex flex-col gap-6">

            <!-- Email card -->
            <div class="bg-surface-container rounded-xl border border-primary/20 p-8">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary mb-4"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <h3 class="text-lg font-bold text-white mb-2">Email Us</h3>
              <a href="mailto:info@hyperlog.aero" class="text-primary hover:text-white transition-colors text-sm font-semibold">info@hyperlog.aero</a>
              <p class="text-xs text-secondary mt-3 leading-relaxed">We typically respond within one business day. We look forward to hearing from you.</p>
            </div>

            <!-- What to expect -->
            <div class="bg-surface-container rounded-xl border border-primary/20 p-8 flex-1">
              <h3 class="text-lg font-bold text-white mb-6">What to Expect</h3>
              <div class="space-y-5">
                <div class="flex gap-4">
                  <div class="w-7 h-7 rounded-full bg-primary/15 flex items-center justify-center shrink-0 mt-0.5">
                    <span class="text-xs font-bold text-primary">1</span>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-white">Initial Conversation</p>
                    <p class="text-xs text-secondary mt-1 leading-relaxed">Understanding your organisation, your role, and how HyperLog can address your specific needs.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-7 h-7 rounded-full bg-primary/15 flex items-center justify-center shrink-0 mt-0.5">
                    <span class="text-xs font-bold text-primary">2</span>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-white">Technical Discussion</p>
                    <p class="text-xs text-secondary mt-1 leading-relaxed">We evaluate how HyperLog's architecture aligns with your regulatory environment and operational requirements.</p>
                  </div>
                </div>
                <div class="flex gap-4">
                  <div class="w-7 h-7 rounded-full bg-primary/15 flex items-center justify-center shrink-0 mt-0.5">
                    <span class="text-xs font-bold text-primary">3</span>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-white">Partnership Scope</p>
                    <p class="text-xs text-secondary mt-1 leading-relaxed">A clear scope of engagement - whether that's a pilot programme, integration discussion, or regulatory collaboration.</p>
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>

        <!-- Office address -->
        <div class="mt-12 bg-surface-container rounded-xl border border-primary/20 p-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <p class="section-label text-primary mb-4">Our Office</p>
              <h3 class="text-lg font-bold text-white mb-4">JetLink Technologies Ltd.</h3>
              <div class="text-sm text-secondary leading-relaxed space-y-1">
                <p>Level 9, Berkeley Square House</p>
                <p>Berkeley Square</p>
                <p>London W1J 6BY</p>
                <p>United Kingdom</p>
              </div>
              <p class="text-xs text-outline/50 mt-4">Company No. 17100204</p>
            </div>
            <div class="rounded-lg overflow-hidden h-[180px]">
              <iframe
                src="https://maps.google.com/maps?q=Berkeley+Square+House,+Berkeley+Square,+London+W1J+6BY&t=&z=15&ie=UTF8&iwloc=&output=embed"
                width="100%"
                height="100%"
                style="border:0; filter: invert(0.9) hue-rotate(180deg) saturate(0.5) brightness(0.7);"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer />

  <!-- Cloudflare Turnstile script -->
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <script>
    // Enable submit button when Turnstile is verified
    window.turnstileCallback = function() {
      const btn = document.getElementById('contact-submit') as HTMLButtonElement;
      if (btn) btn.disabled = false;
    };

    // Watch for Turnstile success via MutationObserver (since we can't use data-callback with async)
    const observer = new MutationObserver(() => {
      const response = document.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      const btn = document.getElementById('contact-submit') as HTMLButtonElement;
      if (response?.value && btn) {
        btn.disabled = false;
      }
    });

    const container = document.getElementById('turnstile-container');
    if (container) {
      observer.observe(container, { childList: true, subtree: true, attributes: true });
    }

    // Scale Turnstile widget to fit container on small screens.
    // Flexible mode has a 300px minimum width that can overflow narrow containers.
    const TURNSTILE_MIN_WIDTH = 300;

    function scaleTurnstile() {
      const wrapper = document.getElementById('turnstile-wrapper');
      const container = document.getElementById('turnstile-container');
      if (!wrapper || !container) return;

      const availableWidth = wrapper.clientWidth;
      if (availableWidth < TURNSTILE_MIN_WIDTH) {
        const scale = availableWidth / TURNSTILE_MIN_WIDTH;
        container.style.transformOrigin = 'left top';
        container.style.transform = `scale(${scale})`;
        // Turnstile widget height is ~65px
        wrapper.style.height = `${65 * scale}px`;
      } else {
        container.style.transform = '';
        container.style.transformOrigin = '';
        wrapper.style.height = '';
      }
    }

    // Run once Turnstile iframe appears, and on resize
    const scaleObserver = new MutationObserver(() => {
      const iframe = document.querySelector('#turnstile-wrapper iframe');
      if (iframe) {
        scaleTurnstile();
        scaleObserver.disconnect();
      }
    });
    const wrapperEl = document.getElementById('turnstile-wrapper');
    if (wrapperEl) scaleObserver.observe(wrapperEl, { childList: true, subtree: true });
    window.addEventListener('resize', scaleTurnstile);

    // Send another message
    document.getElementById('send-another')?.addEventListener('click', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const success = document.getElementById('contact-success');
      form?.reset();
      form?.classList.remove('hidden');
      success?.classList.add('hidden');
      const btn = document.getElementById('contact-submit') as HTMLButtonElement;
      if (btn) { btn.textContent = 'SEND MESSAGE'; btn.disabled = true; }
    });

    // Form submission
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const success = document.getElementById('contact-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('contact-submit') as HTMLButtonElement;
      if (btn) {
        btn.textContent = 'SENDING...';
        btn.disabled = true;
      }

      const formData = new FormData(form);
      const turnstileResponse = document.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            company: formData.get('company'),
            message: formData.get('message'),
            turnstileToken: turnstileResponse?.value || '',
          }),
        });

        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
        } else {
          const data = await res.json();
          alert(data.error || 'Failed to send message. Please try again.');
          if (btn) {
            btn.textContent = 'SEND MESSAGE';
            btn.disabled = false;
          }
        }
      } catch (err) {
        alert('Failed to send message. Please try again.');
        if (btn) {
          btn.textContent = 'SEND MESSAGE';
          btn.disabled = false;
        }
      }
    });
  </script>
</BaseLayout>
